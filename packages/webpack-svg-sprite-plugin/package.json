{
	"name": "@prof-dev/webpack-svg-sprite-plugin",
	"version": "2.0.11",
	"author": "Profesor08",
	"license": "ISC",
	"description": "A Webpack plugin that generates SVG sprites from set of SVG icon files",
	"keywords": [
		"svg icon",
		"svg sprite",
		"svg sprite generator",
		"webpack plugin"
	],
	"publishConfig": {
		"access": "public"
	},
	"main": "./lib/src/webpack-plugin.js",
	"types": "./lib/src/webpack-plugin.d.ts",
	"exports": {
		".": {
			"types": "./lib/src/webpack-plugin.d.ts",
			"import": "./lib/src/webpack-plugin.js",
			"require": "./lib/src/webpack-plugin.js"
		}
	},
	"scripts": {
		"dev": "tsx webpack.ts",
		"build": "rm -rf ./lib && npx tsc",
		"prepublishOnly": "npm run build",
		"test": "echo \"Error: no test specified\" && exit 1"
	},
	"dependencies": {
		"@prof-dev/svg-sprite": "^2.0.0",
		"html-webpack-plugin": "^5.6.3",
		"webpack": "^5.101.0",
		"webpack-dev-server": "^5.2.2"
	}
}
